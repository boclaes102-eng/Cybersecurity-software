# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Build / dist artefacts ───────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
*.spec          # PyInstaller spec (committed manually if needed)
!Static-Malware-Analyzer/sma.spec

# ── PyInstaller runtime hook (auto-generated) ─────────────────────────────────
launcher/_pyi_hook.py

# ── Test caches ───────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.lcov

# ── Tool runtime output ───────────────────────────────────────────────────────
alerts.ndjson
*.ndjson

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code project settings (not source code) ───────────────────────────
.claude/

# ── Secrets / credentials ─────────────────────────────────────────────────────
.env
*.key
*.pem
